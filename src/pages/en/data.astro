---
import Layout from '../../layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getCompanyConfigs, sectorColors } from '../../utils/companyConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Get companies from centralized config
const companies = getCompanyConfigs(t);

const sectors = [...new Set(companies.map((c) => c.sector))];

const categories = [
  {
    icon: '📊',
    title: 'Government Open Data',
    description:
      'Structured datasets and statistical platforms released by government agencies',
    items: [
      {
        name: 'Government Open Data Platform',
        url: 'https://data.gov.tw/',
        desc: 'Central open data portal with tens of thousands of datasets',
      },
      {
        name: 'DGBAS Statistical Database',
        url: 'https://statdb.dgbas.gov.tw/',
        desc: 'Population, economy, price indices and core national statistics',
      },
      {
        name: 'CEC Election Database',
        url: 'https://db.cec.gov.tw/',
        desc: 'Historical election results and voting data',
      },
      {
        name: 'Laws & Regulations Database',
        url: 'https://law.moj.gov.tw/',
        desc: 'Full-text search of all laws, orders, and judicial precedents',
      },
      {
        name: 'Air Quality Monitoring Network',
        url: 'https://airtw.moenv.gov.tw/',
        desc: 'Real-time AQI and PM2.5 monitoring data',
      },
    ],
  },
  {
    icon: '🗺️',
    title: 'Interactive Maps & Visualization',
    description:
      'Real-time monitoring, geographic data, and environmental visualization tools',
    items: [
      {
        name: 'Taiwan Submarine Cable Map',
        url: 'https://smc.peering.tw/',
        desc: 'Community-built real-time submarine cable monitoring — a civic tech exemplar',
      },
      {
        name: 'NLSC Map Service',
        url: 'https://maps.nlsc.gov.tw/',
        desc: 'National land survey maps, aerial photos, and cadastral data',
      },
      {
        name: 'Seismological Center',
        url: 'https://scweb.cwa.gov.tw/',
        desc: 'Real-time earthquake information and historical records',
      },
      {
        name: 'WRA Disaster Prevention',
        url: 'https://fhy.wra.gov.tw/',
        desc: 'Real-time water levels, river monitoring, and reservoir data',
      },
      {
        name: 'Environmental Monitoring',
        url: 'https://env.gov.tw/',
        desc: 'Air quality, UV index, and water quality real-time monitoring',
      },
    ],
  },
  {
    icon: '🤖',
    title: 'Civic Tech',
    description:
      'Open source communities, fact-checking, and digital democracy tools',
    items: [
      {
        name: 'g0v (gov-zero)',
        url: 'https://g0v.tw/',
        desc: "Taiwan's largest open-source civic tech community",
      },
      {
        name: 'g0v Hackathon Events',
        url: 'https://g0v-jothon.kktix.cc/',
        desc: 'Bimonthly hackathons and open data community events',
      },
      {
        name: 'Cofacts',
        url: 'https://cofacts.tw/',
        desc: 'Collaborative fact-checking chatbot for messaging apps',
      },
      {
        name: 'vTaiwan',
        url: 'https://vtaiwan.tw/',
        desc: 'Digital democracy platform for public policy deliberation',
      },
      {
        name: 'JOIN Platform',
        url: 'https://join.gov.tw/',
        desc: 'Government proposals, petitions, and policy discussions',
      },
    ],
  },
  {
    icon: '📰',
    title: 'Data Journalism & Fact-Checking',
    description:
      'Investigative reporting, fact-checking organizations, and data-driven media',
    items: [
      {
        name: 'The Reporter',
        url: 'https://www.twreporter.org/',
        desc: "Taiwan's leading non-profit investigative journalism outlet",
      },
      {
        name: 'Taiwan FactCheck Center',
        url: 'https://tfc-taiwan.org.tw/',
        desc: 'IFCN-certified fact-checking organization',
      },
      {
        name: 'READr',
        url: 'https://www.readr.tw/',
        desc: 'Data journalism and open data visualization',
      },
      {
        name: 'ARTouch',
        url: 'https://artouch.com/',
        desc: "Taiwan's premier art news and criticism platform",
      },
    ],
  },
  {
    icon: '🔬',
    title: 'Academic & Research',
    description: 'Digital archives, ecological data, and AI training corpora',
    items: [
      {
        name: 'Academia Sinica Open Museum',
        url: 'https://openmuseum.tw/',
        desc: 'Digital archives and online curation',
      },
      {
        name: 'National Cultural Memory Bank',
        url: 'https://tcmb.culture.tw/',
        desc: 'Digital preservation of Taiwanese cultural memory',
      },
      {
        name: 'Taiwan Biodiversity Network',
        url: 'https://tbn.biodiv.tw/',
        desc: 'Species distribution and ecological observation data',
      },
      {
        name: 'TAIC — Taiwan AI Corpus',
        url: 'https://huggingface.co/TAIDE',
        desc: "Taiwan's sovereign AI training dataset",
      },
    ],
  },
];
---

<Layout
  title="📊 Data Taiwan — Understanding an Island Through Numbers"
  description="Taiwan's enterprise landscape, SVG resources, open data platforms, civic tech tools, and digital democracy resources"
>
  <div class="data-page">
    <div class="container">
      <!-- Hero -->
      <section class="hero">
        <h1 class="hero-title">
          📊 Data Taiwan — Understanding an Island Through Numbers
        </h1>
        <p class="hero-subtitle">
          From enterprise powerhouses to open data platforms — explore Taiwan
          through curated data storytelling
        </p>
      </section>

      <!-- Act 2: Enterprise Landscape -->
      <section class="enterprise-section">
        <article class="story-block">
          <h2 class="story-title">
            🏢 Enterprise Landscape — How Does One Country Power the Global
            Supply Chain?
          </h2>
          <p>
            Taiwan punches far above its weight in the global economy. This
            country of 23 million people produces over 60% of the world's
            semiconductors, 92% of the most advanced chips, and houses the
            supply chain nerve center for everything from iPhones to Tesla
            vehicles.
          </p>
          <p>
            The interactive bubble chart below reveals Taiwan's economic DNA —
            where <strong
              >TSMC alone represents 39% of Taiwan's total market capitalization</strong
            >, equivalent to the combined value of two-thirds of all other
            listed companies. Behind the "Silicon Shield" narrative lies a
            concentrated ecosystem of precision manufacturing, from Foxconn's
            massive electronics assembly to ASE's semiconductor packaging
            empire.
          </p>
          <p>
            Bubble size represents market cap; color indicates sector. Drag to
            explore, filter by industry, or toggle between market
            cap/revenue/employee count.
          </p>
        </article>

        <div class="controls">
          <div class="size-toggle">
            <label>Bubble size by:</label>
            <button class="toggle-btn active" data-mode="marketCap"
              >Market Cap</button
            >
            <button class="toggle-btn" data-mode="revenue">Revenue</button>
            <button class="toggle-btn" data-mode="employees">Employees</button>
          </div>
          <div class="sector-filters">
            <button class="sector-btn active" data-sector="all">All</button>
            {
              sectors.map((s) => (
                <button
                  class="sector-btn"
                  data-sector={s}
                  style={`--sector-color: ${sectorColors[s] || '#888'}`}
                >
                  <span
                    class="sector-dot"
                    style={`background: ${sectorColors[s] || '#888'}`}
                  />
                  {s}
                </button>
              ))
            }
          </div>
        </div>

        <div id="bubble-chart"></div>

        <div class="insights">
          <h3>🔍 Key Insights</h3>
          <div class="insight-grid">
            <div class="insight-card">
              <div class="insight-number">39%</div>
              <div class="insight-label">
                TSMC's share of Taiwan's total market cap
              </div>
              <div class="insight-detail">
                One company ≈ 2/3 of 1,000+ other listed companies
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-number">72%</div>
              <div class="insight-label">
                Top 50 companies' share of total market cap
              </div>
              <div class="insight-detail">
                Taiwan's stock market highly concentrated in large enterprises
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-number">12</div>
              <div class="insight-label">
                Semiconductor-related companies in top 50
              </div>
              <div class="insight-detail">
                Cementing the "Silicon Shield" — semiconductors are Taiwan's
                national defense
              </div>
            </div>
            <div class="insight-card">
              <div class="insight-number">9</div>
              <div class="insight-label">Financial institutions in top 50</div>
              <div class="insight-detail">
                Post-consolidation, financial sector provides stability
              </div>
            </div>
          </div>
        </div>

        <div class="action-link">
          <a href="/economy" class="btn-action">View full ranking →</a>
        </div>
      </section>

      <!-- Act 3: The Shape of Taiwan -->
      <section class="svg-section">
        <article class="story-block">
          <h2 class="story-title">
            🗺️ The Shape of Taiwan — AI Can't Draw Taiwan Correctly. Here's the
            Real Version.
          </h2>
          <p>
            Most AI image generation models lack structured geographic data for
            Taiwan in their training sets. The result: AI-generated images of
            Taiwan are often distorted, disproportionate, or confused with other
            islands.
          </p>
          <p>
            Taiwan.md provides <strong
              >accurate, open-source, freely usable</strong
            > SVG outlines — a definitive answer for every scenario that needs to
            know "what does Taiwan look like."
          </p>
        </article>

        <div class="svg-grid">
          <div class="svg-card">
            <div class="svg-preview">
              <img src="/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan Icon" />
            </div>
            <div class="svg-info">
              <h4>taiwan-icon.svg</h4>
              <p class="svg-desc">
                Simple outline — Best for icons, logos, small sizes
              </p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-icon-wiki.svg"
                  download
                  class="btn-svg">Download</a
                >
                <button
                  class="btn-svg"
                  onclick="copySVG('taiwan-icon-wiki.svg', this)"
                  >Copy SVG</button
                >
              </div>
            </div>
          </div>

          <div class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-simplemaps.svg"
                alt="Taiwan SimpleMaps"
              />
            </div>
            <div class="svg-info">
              <h4>taiwan-simplemaps.svg</h4>
              <p class="svg-desc">Clean vector — Great for web embedding</p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-simplemaps.svg"
                  download
                  class="btn-svg">Download</a
                >
                <button
                  class="btn-svg"
                  onclick="copySVG('taiwan-simplemaps.svg', this)"
                  >Copy SVG</button
                >
              </div>
            </div>
          </div>

          <div class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-location-map.svg"
                alt="Taiwan Location Map"
              />
            </div>
            <div class="svg-info">
              <h4>taiwan-location-map.svg</h4>
              <p class="svg-desc">
                With coordinates — Ideal for geographic reference
              </p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-location-map.svg"
                  download
                  class="btn-svg">Download</a
                >
                <button
                  class="btn-svg"
                  onclick="copySVG('taiwan-location-map.svg', this)"
                  >Copy SVG</button
                >
              </div>
            </div>
          </div>

          <div class="svg-card">
            <div class="svg-preview">
              <img
                src="/assets/svg/taiwan-political-division.svg"
                alt="Taiwan Political Division"
              />
            </div>
            <div class="svg-info">
              <h4>taiwan-political-division.svg</h4>
              <p class="svg-desc">
                Administrative regions — County/city boundaries
              </p>
              <div class="svg-actions">
                <a
                  href="/assets/svg/taiwan-political-division.svg"
                  download
                  class="btn-svg">Download</a
                >
                <button
                  class="btn-svg"
                  onclick="copySVG('taiwan-political-division.svg', this)"
                  >Copy SVG</button
                >
              </div>
            </div>
          </div>
        </div>

        <div class="usage-example">
          <h4>📝 Usage</h4>
          <div class="code-block">
            <pre><code>&lt;!-- Embed directly --&gt;
&lt;img src="https://taiwan.md/assets/svg/taiwan-icon-wiki.svg" alt="Taiwan" width="200"&gt;

&lt;!-- As CSS background --&gt;
background-image: url('https://taiwan.md/assets/svg/taiwan-icon-wiki.svg');

&lt;!-- In Markdown --&gt;
![Taiwan](https://taiwan.md/assets/svg/taiwan-icon-wiki.svg)</code></pre>
          </div>
          <p class="license-note">
            <strong>License:</strong> All SVG files under <a
              href="https://creativecommons.org/licenses/by-sa/4.0/"
              target="_blank">CC BY-SA 4.0</a
            >. Free to use, modify, and use commercially — just give
            attribution.
          </p>
        </div>

        <div class="action-link">
          <a href="/en/assets" class="btn-action">Browse all SVG assets →</a>
        </div>
      </section>

      <!-- Act 4: Open Data & Digital Democracy -->
      <section class="opendata-section">
        <article class="story-block">
          <h2 class="story-title">
            📡 Open Data & Digital Democracy — 30 Years of Digitization, g0v,
            and the Audrey Tang Effect
          </h2>
          <p>
            Taiwan's digital democracy journey began in 1997 with the
            "Electronic Government Program," but the real transformation came in
            2012 when the Executive Yuan made a pivotal decision: shift from
            "electronic government" to "open government." The launch of
            data.gov.tw in 2013 marked Taiwan's entry into the open data era.
          </p>
          <p>
            What makes Taiwan unique is the <strong
              >g0v (gov-zero) movement</strong
            > — a civic tech community that doesn't just criticize government, but
            rebuilds it. Since 2012, g0v has held over 60 hackathons, generating 900+
            projects, from the COVID-19 mask availability map (600 million queries
            in peak days) to Cofacts fact-checking bot (100,000+ suspicious messages
            processed).
          </p>
          <p>
            The 2016 appointment of g0v participant Audrey Tang as Digital
            Minister institutionalized this collaboration. Taiwan now leads in
            "radical transparency" — from PDIS collaborative meetings to
            vTaiwan's algorithmic consensus-building. The 2022 establishment of
            the Ministry of Digital Affairs (moda) elevated digital governance
            to cabinet level, pushing initiatives like TAIDE (Taiwan's sovereign
            AI model) and "digital resilience" (submarine cable backup plans).
          </p>
          <p>
            <strong>Why Taiwan's digital democracy matters:</strong> When citizens
            can understand data and government releases data, democracy isn't just
            about voting every four years — it becomes daily collaboration.
          </p>
        </article>

        <div class="categories">
          {
            categories.map((cat) => (
              <section class="category-card">
                <div class="category-header">
                  <span class="category-icon">{cat.icon}</span>
                  <div>
                    <h3 class="category-title">{cat.title}</h3>
                    <p class="category-desc">{cat.description}</p>
                  </div>
                </div>
                <ul class="item-list">
                  {cat.items.map((item) => (
                    <li class="item">
                      <a
                        href={item.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="item-link"
                      >
                        {item.name}
                      </a>
                      <span class="item-desc">— {item.desc}</span>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <!-- Act 5: Knowledge Graph Preview -->
      <section class="graph-section">
        <article class="story-block">
          <h2 class="story-title">
            🕸️ Knowledge Graph — Taiwan's Interconnected Landscape
          </h2>
          <p>
            Explore how Taiwan's economy, culture, technology, and society
            interconnect through our interactive knowledge graph. From
            semiconductor supply chains to night market networks, discover the
            hidden relationships that make Taiwan unique.
          </p>
        </article>

        <div class="action-link">
          <a href="/en/graph" class="btn-action">Explore Knowledge Graph →</a>
        </div>
      </section>

      <!-- Footer Links -->
      <footer class="data-footer">
        <div class="footer-links">
          <a href="/economy" class="footer-link">Economy</a>
          <a href="/en/graph" class="footer-link">Knowledge Graph</a>
          <a href="/en/contribute" class="footer-link">Contribute</a>
        </div>
      </footer>
    </div>
  </div>

  <script define:vars={{ companies, sectorColors }}>
    const data = companies;
    const colors = sectorColors;

    const script = document.createElement('script');
    script.src = 'https://d3js.org/d3.v7.min.js';
    script.onload = () => initBubbleChart(data, colors);
    document.head.appendChild(script);

    function initBubbleChart(data, colors) {
      const container = document.getElementById('bubble-chart');
      const width = container.clientWidth;
      const height = Math.max(600, window.innerHeight * 0.6);

      let currentMode = 'marketCap';
      let currentSector = 'all';

      const svg = d3
        .select('#bubble-chart')
        .append('svg')
        .attr('width', width)
        .attr('height', height)
        .attr('viewBox', `0 0 ${width} ${height}`);

      const tooltip = d3
        .select('#bubble-chart')
        .append('div')
        .attr('class', 'tooltip')
        .style('opacity', 0);

      function getValue(d) {
        return d[currentMode] || 0;
      }

      function getRadius(d) {
        const val = getValue(d);
        const maxVal = d3.max(data, getValue);
        const minR = 18;
        const maxR = Math.min(width, height) * 0.18;
        return minR + (maxR - minR) * Math.sqrt(val / maxVal);
      }

      const simulation = d3
        .forceSimulation(data)
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force('charge', d3.forceManyBody().strength(5))
        .force(
          'collision',
          d3
            .forceCollide()
            .radius((d) => getRadius(d) + 2)
            .strength(0.8),
        )
        .force('x', d3.forceX(width / 2).strength(0.05))
        .force('y', d3.forceY(height / 2).strength(0.05));

      const nodes = svg
        .selectAll('g.node')
        .data(data)
        .join('g')
        .attr('class', 'node')
        .call(
          d3
            .drag()
            .on('start', (e, d) => {
              if (!e.active) simulation.alphaTarget(0.3).restart();
              d.fx = d.x;
              d.fy = d.y;
            })
            .on('drag', (e, d) => {
              d.fx = e.x;
              d.fy = e.y;
            })
            .on('end', (e, d) => {
              if (!e.active) simulation.alphaTarget(0);
              d.fx = null;
              d.fy = null;
            }),
        );

      const circles = nodes
        .append('circle')
        .attr('r', (d) => getRadius(d))
        .attr('fill', (d) => colors[d.sector] || '#888')
        .attr('fill-opacity', 0.8)
        .attr('stroke', (d) => colors[d.sector] || '#888')
        .attr('stroke-width', 2)
        .attr('stroke-opacity', 0.3)
        .style('cursor', 'grab');

      const labels = nodes
        .append('text')
        .attr('text-anchor', 'middle')
        .attr('dominant-baseline', 'central')
        .attr('fill', '#fff')
        .attr('font-weight', '600')
        .attr('pointer-events', 'none')
        .each(function (d) {
          const r = getRadius(d);
          const el = d3.select(this);
          const shortName = d.name.split(' ')[0];
          if (r > 50) {
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '-0.4em')
              .attr('font-size', `${Math.min(14, r / 4)}px`)
              .text(shortName);
            el.append('tspan')
              .attr('x', 0)
              .attr('dy', '1.3em')
              .attr('font-size', `${Math.min(11, r / 5)}px`)
              .attr('fill-opacity', 0.8)
              .text(d.marketCap.toLocaleString() + 'B');
          } else if (r > 28) {
            el.attr('font-size', `${Math.min(11, r / 3.5)}px`).text(shortName);
          } else {
            el.attr('font-size', '9px').text(shortName.slice(0, 3));
          }
        });

      nodes
        .on('mouseover', (e, d) => {
          const modeLabel = {
            marketCap: 'Market Cap',
            revenue: 'Revenue',
            employees: 'Employees',
          };
          tooltip.transition().duration(200).style('opacity', 1);
          tooltip
            .html(
              `
            <strong>${d.name}</strong><br/>
            <span style="color:${colors[d.sector] || '#888'}">● ${d.sector}</span><br/>
            Market Cap: ${d.marketCap.toLocaleString()}B TWD<br/>
            Revenue: ${d.revenue.toLocaleString()}B TWD<br/>
            Employees: ${d.employees.toLocaleString()}<br/>
            Founded: ${d.founded}
          `,
            )
            .style('left', e.pageX + 15 + 'px')
            .style('top', e.pageY - 10 + 'px');
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 1)
            .attr('stroke-width', 3);
        })
        .on('mouseout', (e) => {
          tooltip.transition().duration(300).style('opacity', 0);
          d3.select(e.currentTarget)
            .select('circle')
            .attr('fill-opacity', 0.8)
            .attr('stroke-width', 2);
        });

      simulation.on('tick', () => {
        nodes.attr('transform', (d) => {
          d.x = Math.max(getRadius(d), Math.min(width - getRadius(d), d.x));
          d.y = Math.max(getRadius(d), Math.min(height - getRadius(d), d.y));
          return `translate(${d.x},${d.y})`;
        });
      });

      // Toggle size mode
      document.querySelectorAll('.toggle-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.toggle-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentMode = btn.dataset.mode;
          updateBubbles();
        });
      });

      // Sector filter
      document.querySelectorAll('.sector-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document
            .querySelectorAll('.sector-btn')
            .forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          currentSector = btn.dataset.sector;
          updateBubbles();
        });
      });

      function updateBubbles() {
        circles
          .transition()
          .duration(600)
          .attr('r', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return getRadius(d);
          })
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 0.8;
          });

        labels
          .transition()
          .duration(600)
          .attr('fill-opacity', (d) => {
            if (currentSector !== 'all' && d.sector !== currentSector) return 0;
            return 1;
          });

        simulation
          .force(
            'collision',
            d3
              .forceCollide()
              .radius((d) => {
                if (currentSector !== 'all' && d.sector !== currentSector)
                  return 0;
                return getRadius(d) + 2;
              })
              .strength(0.8),
          )
          .alpha(0.6)
          .restart();
      }
    }

    // Copy SVG function
    window.copySVG = async function (filename, btn) {
      try {
        const res = await fetch('/assets/svg/' + filename);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = '✅ Copied';
        setTimeout(() => (btn.textContent = orig), 2000);
      } catch (e) {
        btn.textContent = '❌ Failed';
        setTimeout(() => (btn.textContent = 'Copy SVG'), 2000);
      }
    };
  </script>

  <script is:inline>
    async function copySVG(filename, btn) {
      try {
        const res = await fetch('/assets/svg/' + filename);
        const text = await res.text();
        await navigator.clipboard.writeText(text);
        const orig = btn.textContent;
        btn.textContent = '✅ Copied';
        setTimeout(() => (btn.textContent = orig), 2000);
      } catch (e) {
        btn.textContent = '❌ Failed';
        setTimeout(() => (btn.textContent = 'Copy SVG'), 2000);
      }
    }
  </script>
</Layout>

